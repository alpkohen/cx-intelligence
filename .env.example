# Bu dosyayı kopyalayın: cp .env.example .env
# Aşağıdaki değişkenleri gerçek değerlerle doldurun.

# Anthropic Claude API anahtarı (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tavily arama API anahtarı (tavily.com)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gönderen: Resend yalnızca doğrulanmış domain veya Resend'in test adresi ile çalışır.
# gmail.com/outlook vb. GÖNDEREN adres olarak KULLANILMAZ ("domain doğrulanamadı" hatası).
# Hızlı test: RESEND_FROM_EMAIL=onboarding@resend.dev
# Üretim: kendi domaininizi resend.com/domains üzerinde doğrulayın →ör. no-reply@sizinalanadi.com
RESEND_FROM_EMAIL=onboarding@resend.dev

# Alıcı (virgülle birden fazla). Kendi gmail'inizi buraya yazabilirsiniz.
RESEND_TO_EMAIL=you@gmail.com

# Google Sheets tablo kimliği (URL içinden ?)
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Yerelde ham JSON veya base64 kodlu tek satır (GitHub Actions secret genelde base64)
GOOGLE_SERVICE_ACCOUNT_JSON=

# LinkedIn önerisi + mailde blok: LINKEDIN_ENABLED=1/true/on ile açılır (ekstra Claude çağrısı).
# Boş veya 0 ise kapalı (varsayılan).
# LINKEDIN_ENABLED=1

# Netlify — ses dosyası yayını (netlify_upload.upload_audio)
# NETLIFY_AUTH_TOKEN=
# NETLIFY_SITE_ID=
# NETLIFY_SITE_NAME=uniq-tr
